{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/app",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["src/common/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/plugins/**/*.ts",
    "src/common/**/*.ts",
    "src/preload/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
